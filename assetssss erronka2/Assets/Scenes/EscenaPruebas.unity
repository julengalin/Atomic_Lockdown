  m_Name: 
  m_EditorClassIdentifier: Unity.TextMeshPro::TMPro.TextMeshProUGUI
  m_Material: {fileID: 0}
  m_Color: {r: 1, g: 1, b: 1, a: 1}
  m_RaycastTarget: 1
  m_RaycastPadding: {x: 0, y: 0, z: 0, w: 0}
  m_Maskable: 1
  m_OnCullStateChanged:
    m_PersistentCalls:
      m_Calls: []
  m_text: 'Prozesua beti hasierako disoluzio batekin abiarazten da. Ohikoena sodio
    permanganatoa erabiltzea izaten da, harierako erreakzioa pizteko.


    Saiakuntza
    batzuetan, sodio hidroxidoa izan da gehitzen den hurrengo likidoa. Kasu horietan
    neutralizatzaile gisa amonio hidroxidoa erabiltzen da.


    Beste saiakuntza
    batzuetan, hasierako fasean azido nitrikoa erabili izan da. Kasu horietan, ezinbestekoa
    izan da amaieran disoluzio neutralizatzailea gehitzea, sistema behar bezala egonkortzeko.


    Instalazio
    honetan bestelako fluidoak ere probatu dira - etanola, fluido lubrikatzailea
    eta disoluzio garbitzailea besteak beste- baina ez dute emaitza fidagarririk
    eman fase honetan.


    Oharra: subtantzien arteko ordena eta proportzioak errespetatzen
    ez badira, sistema kutsatu egiten da.'
  m_isRightToLeft: 0
  m_fontAsset: {fileID: 11400000, guid: 4b169b099e17abd42be7fe966880b952, type: 2}
