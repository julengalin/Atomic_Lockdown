--- !u!1001 &1397726142
PrefabInstance:
  m_ObjectHideFlags: 0
  serializedVersion: 2
  m_Modification:
    serializedVersion: 3
    m_TransformParent: {fileID: 1425716346354486387}
    m_Modifications:
    - target: {fileID: 271303484332629963, guid: 7e0ce8243ce29b34992c59ea578bc4f4, type: 3}
      propertyPath: m_text
      value: "\"Oharrak - laborategiko egunerokoa\"\nOraindik harritzen anu zenbaterainoko
        kolore biziak dituzten zenbait substantziak. Azido nitrikoak gorri bizia
        hartzen du argi jakin baten pean, ia kezkagarria.\nSodio permanganatoak,
        berriz more ilun eta sakona dauka, oso erraz bereizten dena.\n\nKolore horiek
        ez dira soilik estetika kontua; askotan, subtantziaren portaera ulertzeko
        lagungarriak dira. \n\nBeste disoluzio batzuk askoz neutroagoak dira, ikusmenari
        dagokionez behintzat.\n"
      objectReference: {fileID: 0}
    - target: {fileID: 271303484332629963, guid: 7e0ce8243ce29b34992c59ea578bc4f4, type: 3}
      propertyPath: m_fontSize
