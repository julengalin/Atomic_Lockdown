--- !u!1001 &6586237463449014013
PrefabInstance:
  m_ObjectHideFlags: 0
  serializedVersion: 2
  m_Modification:
    serializedVersion: 3
    m_TransformParent: {fileID: 8553339981323630078}
    m_Modifications:
    - target: {fileID: 271303484332629963, guid: 7e0ce8243ce29b34992c59ea578bc4f4, type: 3}
      propertyPath: m_text
      value: 'Prozesua beti hasierako disoluzio batekin abiarazten da. Ohikoena sodio
        permanganatoa erabiltzea izaten da, harierako erreakzioa pizteko.


        Saiakuntza
        batzuetan, sodio hidroxidoa izan da gehitzen den hurrengo likidoa. Kasu horietan
        neutralizatzaile gisa amonio hidroxidoa erabiltzen da.


        Beste saiakuntza
        batzuetan, hasierako fasean azido nitrikoa erabili izan da. Kasu horietan,
        ezinbestekoa izan da amaieran disoluzio neutralizatzailea gehitzea, sistema
        behar bezala egonkortzeko.


        Instalazio honetan bestelako fluidoak
        ere probatu dira - etanola, fluido lubrikatzailea eta disoluzio garbitzailea
        besteak beste- baina ez dute emaitza fidagarririk eman fase honetan.


        Oharra:
        subtantzien arteko ordena eta proportzioak errespetatzen ez badira, sistema
        kutsatu egiten da.'
      objectReference: {fileID: 0}
    - target: {fileID: 271303484332629963, guid: 7e0ce8243ce29b34992c59ea578bc4f4, type: 3}
      propertyPath: m_fontSize
      value: 29.3
      objectReference: {fileID: 0}
    - target: {fileID: 1519168349484638024, guid: 7e0ce8243ce29b34992c59ea578bc4f4, type: 3}
      propertyPath: m_Name
